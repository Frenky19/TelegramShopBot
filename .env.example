POSTGRES_DB=telegram_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change_me>
DATABASE_URL=postgresql://postgres:<change_me>@postgres:5432/telegram_shop

DJANGO_SECRET_KEY=<change_me>
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,admin-panel
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:5173
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_TRUST_X_FORWARDED_PROTO=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
PUBLIC_BASE_URL=http://localhost:8000
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=Admin12345!

TELEGRAM_BOT_TOKEN=<change_me>
INTERNAL_SERVICE_TOKEN=<change_me>
BACKEND_URL=http://admin-panel:8000
MEDIA_BASE_URL=http://admin-panel:8000
SETTINGS_CACHE_TTL=30
NOTIFICATION_POLL_INTERVAL=10
BROADCAST_POLL_INTERVAL=30

VITE_PROXY_TARGET=http://admin-panel:8000
VITE_DEV_INIT_DATA=
LOGS_DIR=logs
ADMIN_PANEL_BIND_PORT=18000
WEBAPP_BIND_PORT=18080
GATEWAY_BIND_PORT=18090
